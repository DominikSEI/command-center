# ─── Auth ─────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=your-secure-password

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ─── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# ─── APIs (Phase 2+) ──────────────────────────
GEMINI_API_KEY=

# ─── Anthropic / Claude API ───────────────────
# Du brauchst EINEN von beiden — Anthropic-SDK-Default ist ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=
# Alternativ (Legacy-Naming, gleiche Funktion):
# CLAUDE_API_KEY=

# ─── Agent ────────────────────────────────────
# OPENCLAW_URL: interne Docker-URL, sobald OpenClaw läuft
OPENCLAW_URL=http://openclaw:9000

# ─── Database ─────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
